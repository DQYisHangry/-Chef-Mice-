# Application
APP_ENV=development
SECRET_KEY=change-me-in-production

# Database
# SQLite (default for local dev):
DATABASE_URL=sqlite+aiosqlite:///./meal_planner.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/meal_planner

# LLM
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_MODEL=claude-sonnet-4-6

# Recipe APIs (add whichever you use)
SPOONACULAR_API_KEY=your-spoonacular-api-key-here
EDAMAM_APP_ID=your-edamam-app-id
EDAMAM_APP_KEY=your-edamam-app-key

# Recipe cache TTL in days
RECIPE_CACHE_TTL_DAYS=7
